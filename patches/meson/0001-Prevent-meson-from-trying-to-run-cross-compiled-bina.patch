From d3c21fbc0cb647111394da5ece035a7be75fed32 Mon Sep 17 00:00:00 2001
From: Piotr Stankiewicz <piotr.stankiewicz@docker.com>
Date: Fri, 24 Jan 2025 10:45:25 +0100
Subject: [PATCH 1/3] Prevent meson from trying to run cross compiled binaries

Signed-off-by: Piotr Stankiewicz <piotr.stankiewicz@docker.com>
---
 configure | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/configure b/configure
index 18336376bf..af86457f8a 100755
--- a/configure
+++ b/configure
@@ -1862,6 +1862,8 @@ if test "$skip_meson" = no; then
 
   echo "# Automatically generated by configure - do not modify" > $cross
   echo "[properties]" >> $cross
+  echo "needs_exe_wrapper = true" >> $cross
+  echo "skip_sanity_check = true" >> $cross
 
   # unroll any custom device configs
   for a in $device_archs; do
-- 
